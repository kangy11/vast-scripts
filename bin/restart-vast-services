#!/usr/bin/env bash
set -Eeuo pipefail

OFFICIAL_COMFY_SUPERVISOR="/opt/supervisor-scripts/comfyui.sh"
SUPERVISORD_CONF="/etc/supervisor/supervisord.conf"
SUPERVISOR_PID_FILE="/var/run/supervisord.pid"
SUPERVISOR_SOCK="/var/run/supervisor.sock"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-/workspace}"
ENV_FILE="$WORKSPACE_ROOT/.env"
PROC1_ENV_FILE="/proc/1/environ"
SERVICES=(
  comfyui
  instance_portal
  caddy
  tunnel_manager
  api-wrapper
)
PORTAL_ENV_NAMES=(
  WORKSPACE
  PORTAL_CONFIG
  WEB_USERNAME
  WEB_PASSWORD
  OPEN_BUTTON_TOKEN
  ENABLE_AUTH
  ENABLE_HTTPS
  AUTH_EXCLUDE
  PUBLIC_IPADDR
  VAST_CONTAINERLABEL
  VAST_TCP_PORT_1111
  VAST_TCP_PORT_8188
  VAST_TCP_PORT_8288
  VAST_TCP_PORT_8384
  VAST_TCP_PORT_8080
  COMFYUI_ARGS
  COMFYUI_PORT
)
PORT_REGEX='1111|11111|8188|18188|8288|18288|8384|18384'
SUPERVISORD_ERR_LOG="$(mktemp /tmp/restart-vast-services.XXXXXX.log)"

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

recover_vast_env_from_proc1() {
  [[ -r "$PROC1_ENV_FILE" ]] || return 0
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    key="${line%%=*}"
    value="${line#*=}"
    for wanted in "${PORTAL_ENV_NAMES[@]}"; do
      if [[ "$key" == "$wanted" && -z "${!key:-}" && -n "$value" ]]; then
        export "$key=$value"
      fi
    done
  done < <(tr '\0' '\n' < "$PROC1_ENV_FILE")
}

persist_recovered_env() {
  local tmp_env tmp_etc line key name
  tmp_env="$(mktemp /tmp/vast-env.XXXXXX)"
  if [[ -f "$ENV_FILE" ]]; then
    while IFS= read -r line; do
      key="${line#export }"
      key="${key%%=*}"
      local keep=1
      for name in "${PORTAL_ENV_NAMES[@]}"; do
        if [[ "$key" == "$name" ]]; then
          keep=0
          break
        fi
      done
      if [[ $keep -eq 1 ]]; then
        printf '%s\n' "$line" >>"$tmp_env"
      fi
    done < "$ENV_FILE"
  fi
  for name in "${PORTAL_ENV_NAMES[@]}"; do
    if [[ -n "${!name:-}" ]]; then
      printf 'export %s=%q\n' "$name" "${!name}" >>"$tmp_env"
    fi
  done
  install -m 600 "$tmp_env" "$ENV_FILE"
  rm -f "$tmp_env"

  tmp_etc="$(mktemp /tmp/etc-environment.XXXXXX)"
  if [[ -f /etc/environment ]]; then
    while IFS= read -r line; do
      key="${line%%=*}"
      local keep=1
      for name in "${PORTAL_ENV_NAMES[@]}"; do
        if [[ "$key" == "$name" ]]; then
          keep=0
          break
        fi
      done
      if [[ $keep -eq 1 ]]; then
        printf '%s\n' "$line" >>"$tmp_etc"
      fi
    done < /etc/environment
  fi
  for name in "${PORTAL_ENV_NAMES[@]}"; do
    if [[ -n "${!name:-}" ]]; then
      printf '%s=%q\n' "$name" "${!name}" >>"$tmp_etc"
    fi
  done
  install -m 644 "$tmp_etc" /etc/environment
  rm -f "$tmp_etc"
}

cleanup_supervisor_state() {
  if [[ -f "$SUPERVISOR_PID_FILE" ]]; then
    pid="$(cat "$SUPERVISOR_PID_FILE" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$SUPERVISOR_PID_FILE" "$SUPERVISOR_SOCK"
    fi
  fi
}

stop_portal_processes() {
  local patterns=(
    "supervisord"
    "caddy"
    "instance_portal"
    "tunnel_manager"
    "api-wrapper"
    "python.*main.py.*18188"
    "python.*main.py.*8188"
  )

  for pattern in "${patterns[@]}"; do
    pkill -f "$pattern" 2>/dev/null || true
  done

  sleep 2
  rm -f "$SUPERVISOR_PID_FILE" "$SUPERVISOR_SOCK"
}

start_supervisord() {
  cleanup_supervisor_state

  if supervisorctl status >/dev/null 2>&1; then
    return 0
  fi

  if pgrep -x supervisord >/dev/null 2>&1; then
    pkill -x supervisord 2>/dev/null || true
    sleep 2
    rm -f "$SUPERVISOR_PID_FILE" "$SUPERVISOR_SOCK"
  fi

  if supervisord -c "$SUPERVISORD_CONF" 2>"$SUPERVISORD_ERR_LOG"; then
    sleep 3
    return 0
  fi

  if grep -q "Another program is already listening on a port" "$SUPERVISORD_ERR_LOG"; then
    echo "Found leftover Vast web processes holding official ports; stopping them and retrying supervisord."
    stop_portal_processes
    if supervisord -c "$SUPERVISORD_CONF" 2>"$SUPERVISORD_ERR_LOG"; then
      sleep 3
      return 0
    fi
  fi

  cat "$SUPERVISORD_ERR_LOG" >&2 || true
  return 1
}

if [[ ! -e "$OFFICIAL_COMFY_SUPERVISOR" ]]; then
  echo "Official Vast ComfyUI image not detected; this helper is intended for the official supervisor-managed stack." >&2
  exit 1
fi

if [[ "$(id -u)" -ne 0 ]]; then
  echo "Please run this command as root." >&2
  exit 1
fi

recover_vast_env_from_proc1
persist_recovered_env

if ! supervisorctl status >/dev/null 2>&1; then
  start_supervisord
fi

for service in "${SERVICES[@]}"; do
  if supervisorctl status "$service" >/dev/null 2>&1; then
    supervisorctl restart "$service"
  fi
done

sleep 5

echo
echo "Supervisor status:"
supervisorctl status || true

echo
echo "Relevant listeners:"
ss -ltnp | grep -E "$PORT_REGEX|22" || true

#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-$REPO_ROOT/.bootstrap-venv/bin/python}"

exec "$PYTHON_BIN" "$REPO_ROOT/bootstrap/bootstrap.py" --repo-root "$REPO_ROOT" sync-models "$@"

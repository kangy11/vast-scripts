BOOTSTRAP_REPO=https://github.com/your-user/vast-comfy-bootstrap.git
BOOTSTRAP_REF=main
BOOTSTRAP_ROOT=/workspace/bootstrap
WORKSPACE_ROOT=/workspace
COMFYUI_ROOT=/workspace/ComfyUI
COMFYUI_REPO=https://github.com/comfyanonymous/ComfyUI.git
COMFYUI_REF=
COMFYUI_PORT=18188
COMFYUI_ARGS=
AUTO_START_COMFYUI=0
OFFICIAL_COMFYUI_FALLBACK=0
SYNC_MODELS_ON_BOOT=1
# Optional override for manual launches. Official Vast ComfyUI images already log here.
COMFYUI_LOG_FILE=/var/log/portal/comfyui.log
WEB_USERNAME=vastai
WEB_PASSWORD=change-this-to-a-strong-password
# Set one of HF_TOKEN / HUGGING_FACE_HUB_TOKEN / HUGGINGFACEHUB_API_TOKEN
# as a Vast account or template secret, not in a public template.
# Leave HF_HOME / HF_HUB_CACHE unset unless you explicitly want a custom cache path.
